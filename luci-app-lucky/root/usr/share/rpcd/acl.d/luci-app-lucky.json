{
    "luci-app-lucky": {
        "description": "Grant access to luci-app-lucky RPC methods",
        "read": {
            "ubus": {
                "luci.lucky": [
                    "get_status",
                    "get_arch",
                    "get_system_info",
                    "get_update_status",
                    "get_auto_update_log"
                ]
            }
        },
        "write": {
            "ubus": {
                "luci.lucky": [
                    "reset_user",
                    "get_upstream_version",
                    "do_update"
                ]
            }
        }
    }
}
