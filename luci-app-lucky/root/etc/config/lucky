config lucky 'lucky'
	option enabled       '0'
	option logger        '1'
	option port          '16601'
	option safe          ''
	option ssl           '0'
	option delay         '60'
	option configdir     '/etc/config/lucky.daji'
	option binpath       '/usr/bin/lucky'
