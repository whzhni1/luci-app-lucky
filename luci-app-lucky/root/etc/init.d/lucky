#!/bin/sh /etc/rc.common
START=99
STOP=15
USE_PROCD=1

CONF=lucky
PROG=/usr/bin/lucky
CONFDIR=/etc/config/lucky.daji
CRON_FILE=/etc/crontabs/root
CRON_TAG=luci-app-lucky-autoupdate
UPDATE_SCRIPT=/usr/libexec/lucky-update.sh

uci_get() { uci -q get "$CONF.$CONF.$1" 2>/dev/null || echo "${2}"; }

log_msg() { logger -t lucky -p daemon.info "$1"; }

sync_cron() {
    local auto_update interval new_entry

    auto_update=$(uci_get auto_update 0)
    interval=$(uci_get update_interval 7)

    sed -i "/${CRON_TAG}/d" "$CRON_FILE" 2>/dev/null

    if [ "$auto_update" = "1" ]; then
        new_entry="0 3 */${interval} * * $UPDATE_SCRIPT >> /tmp/lucky_update/autoupdate.log 2>&1 #${CRON_TAG}"
        echo "$new_entry" >> "$CRON_FILE"
        log_msg "Auto update cron set: every ${interval} day(s)"
    else
        log_msg "Auto update cron removed."
    fi

    /etc/init.d/cron restart 2>/dev/null
}

start_service() {
    local enabled binpath configdir port safe delay

    enabled=$(uci_get enabled 0)
    [ "$enabled" = "1" ] || { log_msg "Lucky is disabled, skipping start."; return 0; }

    binpath=$(uci_get binpath "$PROG")
    configdir=$(uci_get configdir "$CONFDIR")

    if [ ! -x "$binpath" ]; then
        if [ -x "$UPDATE_SCRIPT" ] && [ ! -f /tmp/lucky_downloading ]; then
            touch /tmp/lucky_downloading
            log_msg "Lucky binary not found, starting automatic download..."
            setsid sh -c "$UPDATE_SCRIPT >/dev/null 2>&1; rm -f /tmp/lucky_downloading" &
        fi
        return 0
    fi

    port=$(uci_get port 16601)
    safe=$(uci_get safe "" | tr -d '[:space:]')
    delay=$(uci_get delay 60)

    [ -d "$configdir" ] || mkdir -p "$configdir"

    [ "$(awk -F. '{print $1}' /proc/uptime)" -lt 120 ] && {
        log_msg "Delaying start by ${delay}s..."
        sleep "$delay"
    }

    "$binpath" -setconf -key AdminWebListenPort -value "$port" -cd "$configdir" >/dev/null 2>&1

    if [ -z "$safe" ]; then
        "$binpath" -rCancelSafeURL -cd "$configdir" >/dev/null 2>&1
    else
        "$binpath" -setconf -key SafeURL -value "$safe" -cd "$configdir" >/dev/null 2>&1
    fi

    procd_open_instance
    procd_set_param command "$binpath" -cd "$configdir"
    procd_set_param respawn
    procd_set_param stderr 1
    procd_close_instance

    log_msg "Lucky started (port=${port} configdir=${configdir})"
}

stop_service() { log_msg "Lucky stopped."; }

reload_service() { stop; start; sync_cron; }

service_triggers() { procd_add_reload_trigger lucky; }